          "text": "<span style=\"font-size: 28px;\"><span style=\"font-size: 32px;\"><span style=\"font-size: 40px;\">MONKEY</span></span></span><br><span style=\"font-size: 12px;\"><span style=\"font-size: 10px;\"><span style=\"font-size: 16px;\"><span style=\"font-size: 14px;\"><span style=\"font-size: 11px;\">THE ULTIMATE TELLYFRIEND</span></span></span></span></span>"
