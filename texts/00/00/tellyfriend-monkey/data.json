          "text": "<div style=\"text-align: center;\"><span style=\"font-size: 28px;\">Now you</span></div><div style=\"text-align: center;\"><span style=\"font-size: 28px;\">can be like</span></div><div style=\"text-align: center;\"><span style=\"font-size: 28px;\">Al too!</span></div><div style=\"text-align: center;\"><span style=\"font-size: 12px;\">(Look at the back</span></div><div style=\"text-align: center;\"><span style=\"font-size: 12px;\">for more details)</span></div>"
